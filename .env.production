# Public, browser-safe Supabase config for the production build.
# NEXT_PUBLIC_* values are inlined into the client bundle at build time and are
# public by design (the anon key is meant to be shipped to the browser), so it
# is safe to commit them here. RLS protects the data, not this key.
#
# The Anthropic key is a SECRET and is intentionally NOT here — set
# ANTHROPIC_API_KEY in the Vercel project's Environment Variables to enable the
# AI coaching report.
NEXT_PUBLIC_SUPABASE_URL=https://kafrpvzbtlusurcknovl.supabase.co
