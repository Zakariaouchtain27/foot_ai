# Supabase public (browser-safe) credentials for the Next.js client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic API key — SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix), used by the
# /api/coaching route to generate AI coaching reports. Get one at
# https://console.anthropic.com/ . Without it, the rest of the app still works;
# only the "Generate AI coaching report" button is disabled.
ANTHROPIC_API_KEY=sk-ant-...
